# Control plane endpoint
KEPAGENT_API_BASE_URL=https://your-control-plane.example.com

# Agent credentials
KEPAGENT_API_KEY=replace-with-agent-api-key

# Optional global fallback: leave empty when RCON passwords are provided per server or by the control plane
KEPAGENT_RCON_PASSWORD=

# Seconds to wait between starts when one command starts two or more servers
KEPAGENT_BATCH_START_INTERVAL_SECONDS=30
